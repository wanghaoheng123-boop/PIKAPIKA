{
  "name": "pikapika-functions",
  "version": "0.1.0",
  "private": true,
  "description": "Firebase Cloud Functions for PIKAPIKA — AI proxy, gallery, notifications.",
  "main": "lib/index.js",
  "engines": { "node": "20" },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "lint": "eslint --ext .ts src"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "@anthropic-ai/sdk": "^0.27.0",
    "openai": "^4.60.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.4.0"
  }
}
